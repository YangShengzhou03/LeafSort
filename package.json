{
  "name": "leafsort-pro",
  "version": "1.0.0",
  "description": "智能相册管理系统 - Vue3 + Element Plus + Electron",
  "author": "LeafSort Pro Team",
  "license": "MIT",
  "private": true,
  "scripts": {
    "electron": "concurrently \"npm run server\" \"wait-on http://localhost:8080 && electron . --dev\"",
    "server": "vue-cli-service serve",
    "lint": "eslint --ext .js,.vue src",
    "pack-clean": "if exist dist rmdir /s /q dist && if exist dist-electron rmdir /s /q dist-electron && npm run pack"
  },
  "main": "electron/main.js",
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "core-js": "^3.8.3",
    "element-plus": "^2.4.4",
    "pinia": "^2.1.7",
    "vue": "^3.2.13",
    "vue-router": "^4.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.12.16",
    "@babel/eslint-parser": "^7.12.16",
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-plugin-eslint": "~5.0.0",
    "@vue/cli-plugin-router": "~5.0.0",
    "@vue/cli-service": "~5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^27.0.0",
    "eslint": "^7.32.0",
    "eslint-plugin-vue": "^8.7.1",
    "wait-on": "^9.0.3"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "@babel/eslint-parser",
      "requireConfigFile": false
    },
    "rules": {
      "no-unused-vars": "warn",
      "no-console": "warn"
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "build": {
    "appId": "com.leafsort.app",
    "productName": "LeafSort",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "icon": "build/icon.icns"
    },
    "win": {
      "icon": "build/icon.ico"
    },
    "linux": {
      "icon": "build/icon.png"
    }
  }
}
