{
  "name": "leafview",
  "version": "1.0.0",
  "description": "基于 Electron + Vue3 + Element Plus 的现代数字资产管理工具，对标 Eagle 软件",
  "main": "electron/main.ts",
  "scripts": {
    "dev": "vite",
    "build-vue": "vite build",
    "build-electron": "node build-electron.js",
    "build": "npm run build-vue && npm run build-electron && electron-builder",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build",
    "pack": "electron-builder --dir",
    "clean": "rimraf dist dist-electron release",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.1.0",
    "axios": "^1.4.0",
    "chokidar": "^3.5.3",
    "crypto-js": "^4.1.1",
    "element-plus": "^2.3.8",
    "exifreader": "^4.0.0",
    "file-type": "^18.0.0",
    "fs-extra": "^11.1.1",
    "image-size": "^1.0.2",
    "pinia": "^2.1.6",
    "vue": "^3.3.4",
    "vue-router": "^4.2.4"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/fs-extra": "^11.0.2",
    "@types/node": "^18.17.11",
    "@vitejs/plugin-vue": "^4.2.3",
    "@vue/tsconfig": "^0.4.0",
    "concurrently": "^8.0.1",
    "electron": "^23.0.0",
    "electron-builder": "^24.6.3",
    "rimraf": "^5.0.1",
    "sass": "^1.94.2",
    "terser": "^5.44.1",
    "typescript": "^5.0.2",
    "vite": "^4.3.9",
    "vite-plugin-electron": "^0.29.0",
    "vue-tsc": "^1.4.2",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.leafview.app",
    "productName": "LeafView",
    "copyright": "Copyright © 2024 LeafView",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "icon": "resources/icons/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "resources/icons/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "category": "Graphics",
      "icon": "resources/icons"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icons/installer.ico",
      "uninstallerIcon": "resources/icons/uninstaller.ico",
      "installerHeaderIcon": "resources/icons/installer.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LeafView"
    }
  }
}
